{
   "extends": "@bookmark-manager/config/tsconfig",
   "compilerOptions": {
      "module": "esnext",
      "moduleResolution": "bundler",
      "target": "ES2022",
      "lib": ["dom", "dom.iterable", "esnext"],
      "jsx": "preserve",
      "allowJs": true,
      "esModuleInterop": true,
      "incremental": true,
      "plugins": [{ "name": "next" }],
      "paths": {
         "@/*": ["./src/*"]
      }
   },
   "include": ["next-env.d.ts", "**/*.ts", "**/*.mts", "**/*.tsx", ".next/types/**/*.ts"],
   "exclude": ["node_modules"]
}
