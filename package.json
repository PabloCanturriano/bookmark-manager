{
   "name": "bookmark-manager",
   "private": true,
   "scripts": {
      "dev": "turbo run dev",
      "build": "turbo run build",
      "test": "turbo run test",
      "lint": "turbo run lint",
      "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
      "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\""
   },
   "devDependencies": {
      "prettier": "^3.4.2",
      "turbo": "^2.3.3",
      "typescript": "^5.7.3"
   },
   "packageManager": "pnpm@9.15.4"
}
